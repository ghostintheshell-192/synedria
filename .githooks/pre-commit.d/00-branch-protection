#!/bin/bash
# Pre-commit Hook Module: Branch Protection
# Blocks direct commits on protected branches (main, develop)

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)
GIT_DIR=$(git rev-parse --git-dir 2>/dev/null)

echo -e "${GREEN}[Branch Protection]${NC} Checking current branch..."

# Allow merge commits on protected branches. The block is for direct
# commits; merges are the expected way to get work into main/develop.
if [ -f "$GIT_DIR/MERGE_HEAD" ]; then
    echo -e "${GREEN}✓ Merge commit on '$BRANCH' allowed${NC}"
    exit 0
fi

# Allow the spec-bookkeeping amend that post-merge asks for: HEAD is a
# merge commit not yet on any remote, and the staged changes touch ONLY
# .development/specs/. Anything else stays blocked.
if [ "$(git rev-list --parents -n 1 HEAD 2>/dev/null | wc -w)" -ge 3 ] \
    && [ -z "$(git branch -r --contains HEAD 2>/dev/null)" ] \
    && [ -n "$(git diff --cached --name-only)" ] \
    && [ -z "$(git diff --cached --name-only | grep -v '^\.development/specs/')" ]; then
    echo -e "${GREEN}✓ Spec bookkeeping on unpushed merge commit allowed${NC}"
    exit 0
fi

if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "develop" ]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════${NC}"
    echo -e "${RED}  COMMIT BLOCCATO: branch protetto '$BRANCH'${NC}"
    echo -e "${RED}═══════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${YELLOW}Crea un feature branch:${NC}"
    echo ""
    echo "  git checkout -b feature/nome-feature"
    echo "  git checkout -b fix/nome-bug"
    echo "  git checkout -b refactor/descrizione"
    echo ""
    echo -e "${YELLOW}Per bypass (NON RACCOMANDATO):${NC}"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ Branch '$BRANCH' OK${NC}"
exit 0
