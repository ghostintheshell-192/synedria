#!/bin/bash
# Pre-commit hook module: formatting gate (generic orchestrator, ADR-012).
# Delegates entirely to the project's standard entry point; this hook has
# no knowledge of the stack or its formatter. If the entry point is absent,
# the project does not offer the capability: skip silently.

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
ENTRY_POINT="$PROJECT_ROOT/.development/automation/format-check.sh"

if [[ ! -x "$ENTRY_POINT" ]]; then
    exit 0
fi

# Pass the staged files; the entry point decides which ones it cares about.
mapfile -t STAGED < <(git diff --cached --name-only --diff-filter=ACM)
if [[ ${#STAGED[@]} -eq 0 ]]; then
    exit 0
fi

echo -e "${BLUE}[02] Format Check${NC}"

if OUTPUT=$(cd "$PROJECT_ROOT" && "$ENTRY_POINT" "${STAGED[@]}" 2>&1); then
    echo -e "  ${GREEN}✓${NC} ${OUTPUT##*$'\n'}"
    exit 0
fi

echo -e "$OUTPUT"
echo ""
echo -e "${RED}Commit blocked: formatting check failed.${NC}"
echo -e "${YELLOW}To bypass (NOT RECOMMENDED):${NC} git commit --no-verify"
exit 1
