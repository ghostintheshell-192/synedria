{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "Bash(npx supabase:*)",
      "Bash(gh run view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "WebSearch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.development/scripts/generate-index.py\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.development/scripts/update-tech-debt-index.py\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'cat | python3 \"$(git rev-parse --show-toplevel)/.development/scripts/session-archive.py\"'"
          }
        ]
      }
    ]
  }
}
